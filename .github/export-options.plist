<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>method</key>
    <string>development</string>
    <!--
    For distribution with notarization, change method to "developer-id" and:
    - Set teamID below to your Apple Team ID
    - Configure signingStyle: "manual"
    - Set signingCertificate: "Developer ID Application"
    - Pass APPLE_TEAM_ID secret in the workflow (already wired up)

    The "development" method uses ad-hoc signing and works on CI runners
    without a Developer ID certificate. It is sufficient for testing.
    -->
</dict>
</plist>
