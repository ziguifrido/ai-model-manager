<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>method</key>
    <string>developer-id</string>
    <key>teamID</key>
    <string>YOUR_TEAM_ID_HERE</string>
    <!--
    For notarization, configure:
    - signingStyle: "manual"
    - teamID: Your Apple Team ID
    - signingCertificate: "Developer ID Application"

    Leave teamID as YOUR_TEAM_ID_HERE for local builds.
    Local development builds work without code signing.
    -->
</dict>
</plist>
